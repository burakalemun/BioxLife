# ============================================================
# BioxLife — Backend Environment Variables
# Bu dosyayı .env olarak kopyala: cp .env.example .env
# .env dosyasını ASLA git'e commit etme!
# ============================================================

# ── Veritabanı (Supabase) ──────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Redis (Upstash) ───────────────────────────────────────
REDIS_URL=redis://default:[PASSWORD]@[HOST].upstash.io:6379

# ── Medusa ────────────────────────────────────────────────
MEDUSA_ADMIN_ONBOARDING_TYPE=default
JWT_SECRET=buraya-cok-uzun-ve-rastgele-bir-string-gir
COOKIE_SECRET=buraya-baska-bir-cok-uzun-rastgele-string-gir

# ── Storefront URL ────────────────────────────────────────
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:9000

# ── Cloudinary (Ürün Görselleri) ─────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── E-posta (Resend) ──────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@bioxlife.com.tr

# ── SMS (Netgsm) ──────────────────────────────────────────
NETGSM_USER=
NETGSM_PASSWORD=
NETGSM_SENDER=BIOXLIFE

# ── Ödeme (Sonra eklenecek) ───────────────────────────────
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://api.iyzipay.com
